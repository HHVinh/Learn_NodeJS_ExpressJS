<form class="mt-4" name="container-form" method="POST" action="/courses/handle-form-actions">
    <div class="align-items-center justify-content-between">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <h1>Khóa học của tôi</h1>
                <a href="/me/trash/courses">Thùng rác ({{deletedCount}})</a>
            </div>
            <a href="/courses/create" class="btn btn-primary">Tạo khóa học</a>
        </div>

        <div>
            <div class="mt-4 d-flex align-items-center">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" value="" id="checkbox-all">
                    <label class="form-check-label" for="checkbox-all">
                        Chọn tất cả
                    </label>
                </div>

                <select class="form-select form-select-sm checkbox-select-all-options" name="action" required>
                    <option value="">--- Chọn hành động ---</option>
                    <option value="delete">Xóa</option>
                </select>

                <button class="btn btn-primary btn-sm check-all-submit-btn" disabled>Thực hiện</button>
            </div>
        </div>
    </div>

    <table class="table mt-4">
        <thead>
            <tr>
                <th scope="col">Chọn</th>
                <th scope="col">STT</th>
                <th scope="col">Tên khóa học</th>
                <th scope="col">Trình độ</th>
                <th scope="col" colspan="2">Thời gian</th>
            </tr>
        </thead>

        <tbody>
            {{#each courses}}
            <tr>
                <td>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="courseIds[]" value="{{this._id}}">
                    </div>
                </td>
                <th scope="row">{{sum @index 1}}</th>
                <td>{{this.name}}</td>
                <td>{{this.level}}</td>
                <td>
                    {{#if this.updatedAt}}
                        {{this.updatedAt}}
                    {{else}}
                        {{this.createdAt}}
                    {{/if}}
                </td>
                <td>
                    <a href="/courses/{{this._id}}/edit">Sửa</a>
                </td>
                <td>
                    <a href="#" data-id="{{this._id}}" data-bs-toggle="modal" data-bs-target="#delete-course-modal">Xóa</a>
                </td>
            </tr>
            {{else}}
            <tr>
                <td colspan="5" class="text-center">
                    <p>Bạn chưa có khóa học nào</p>
                    <a href="/courses/create">Đăng khóa học</a>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</form>


{{!-- Confirm delete course modal --}}
<div class="modal" id="delete-course-modal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Xác nhận xóa khóa học</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p>Bạn có chắc chắn muốn xóa khóa học này?</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
        <button type="button" id="btn-confirm-delete" class="btn btn-danger">Xóa</button>
      </div>
    </div>
  </div>
</div>


{{!-- Delete Hidden Form --}}
<form method="POST" id="delete-course-form"></form> 


{{!-- Delete Course Script --}}
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var courseId;
        var deleteForm = document.getElementById("delete-course-form");
        var containerForm = document.querySelector('form[name="container-form"]');
        var btnConfirmDelete = document.getElementById("btn-confirm-delete");
        var deleteModal = document.getElementById("delete-course-modal");
        var checkboxAll = document.getElementById("checkbox-all");
        var courseItemCheckbox = document.querySelectorAll('input[name="courseIds[]"]');
        var checkAllSubmitBtn = document.querySelector('.check-all-submit-btn');
        var actionSelect = document.querySelector('select[name="action"]');

        // Khi modal được mở, lấy courseId từ nút "Xóa" đã click
        deleteModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;  // Nút "Xóa" đã click
            courseId = button.getAttribute('data-id');
        });

        // Khi click nút "Xóa" trong modal
        btnConfirmDelete.addEventListener('click', function () {
            deleteForm.action = "/courses/" + courseId + "?_method=DELETE";
            deleteForm.submit();
        });

        // Checkbox all click
        checkboxAll.addEventListener('change', function () {
            var isCheckAll = checkboxAll.checked;
            courseItemCheckbox.forEach(function (checkbox) {
                checkbox.checked = isCheckAll;
            });
            renderCheckAllSubmitBtn();
        });

        // Course item checkbox change
        courseItemCheckbox.forEach(function (checkbox) {
            checkbox.addEventListener('change', function () {
                var isCheckedAll = courseItemCheckbox.length === Array.from(courseItemCheckbox).filter(checkbox => checkbox.checked).length;
                checkboxAll.checked = isCheckedAll;
                
                renderCheckAllSubmitBtn();
            });
        });

        // Lắng nghe sự kiện người dùng đổi lựa chọn hành động (VD: từ trống -> chọn "Xóa")
        actionSelect.addEventListener('change', function () {
            renderCheckAllSubmitBtn();
        });

        // Re-render check all submit button
        function renderCheckAllSubmitBtn() {
            var checkedCount = document.querySelectorAll('input[name="courseIds[]"]:checked').length;
            var isActionSelected = actionSelect.value !== ""; // Phải chọn hành động khác chuỗi rỗng
            
            // Nút bấm chỉ được mở KHI VÀ CHỈ KHI thỏa mãn ĐỒNG THỜI 2 điều kiện
            if (checkedCount > 0 && isActionSelected) {
                checkAllSubmitBtn.removeAttribute('disabled'); // Mở khóa nút
            } else {
                checkAllSubmitBtn.setAttribute('disabled', 'disabled'); // Đóng khóa nút
            }
        }
    });
</script>
