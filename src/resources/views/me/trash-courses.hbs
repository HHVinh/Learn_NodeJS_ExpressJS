<div class="mt-4">
    <div>
        <h1>Khóa học đã xóa</h1>
        <a href="/me/stored/courses">Khóa học của tôi</a>
    </div>

    <table class="table mt-4">
        <thead>
            <tr>
                <th scope="col">STT</th>
                <th scope="col">Tên khóa học</th>
                <th scope="col">Trình độ</th>
                <th scope="col" colspan="2">Thời gian</th>
            </tr>
        </thead>

        <tbody>
            {{#each courses}}
            <tr>
                <th scope="row">{{sum @index 1}}</th>
                <td>{{this.name}}</td>
                <td>{{this.level}}</td>
                <td>
                    {{#if this.updatedAt}}
                        {{this.updatedAt}}
                    {{else}}
                        {{this.createdAt}}
                    {{/if}}
                </td>
                <td>
                    <a href="" class="btn-restore" data-id="{{this._id}}">Khôi phục</a>
                </td>
                <td>
                    <a href="#" data-id="{{this._id}}" data-bs-toggle="modal" data-bs-target="#delete-course-modal">Xóa vĩnh viễn</a>
                </td>
            </tr>
            {{else}}
            <tr>
                <td colspan="5" class="text-center">
                    <p>Thùng rác rỗng</p>
                    <a href="/me/stored/courses">Quay lại danh sách khóa học</a>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>


{{!-- Confirm delete course modal --}}
<div class="modal" id="delete-course-modal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Xác nhận xóa khóa học</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p>Bạn có chắc chắn muốn XÓA VĨNH VIỄN khóa học này?</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
        <button type="button" id="btn-confirm-delete" class="btn btn-danger">Xóa vĩnh viễn</button>
      </div>
    </div>
  </div>
</div>


{{!-- Delete Hidden Form --}}
<form method="POST" id="delete-course-form"></form>

{{!-- Restore Hidden Form --}}
<form method="POST" id="restore-course-form"></form>


{{!-- Delete Course Script --}}
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var courseId;
        var deleteForm = document.getElementById('delete-course-form');
        var restoreForm = document.getElementById('restore-course-form');
        var btnConfirmDelete = document.getElementById('btn-confirm-delete');
        var deleteModal = document.getElementById('delete-course-modal');
        var restoreBtns = document.querySelectorAll('.btn-restore');

        // Khi modal được mở, lấy courseId từ nút "Xóa" đã click
        deleteModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            courseId = button.getAttribute('data-id');
        });

        // Khi click nút "Xóa bỏ" trong modal
        btnConfirmDelete.addEventListener('click', function () {
            deleteForm.action = '/courses/' + courseId + '/force?_method=DELETE';
            deleteForm.submit();
        });

        // Restore btn click
        restoreBtns.forEach(function (btn) {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                var courseId = this.getAttribute('data-id');
                restoreForm.action = '/courses/' + courseId + '/restore?_method=PATCH';
                restoreForm.submit();
            });
        });
    });
</script>
